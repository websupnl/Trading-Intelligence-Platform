# Trading OS - Environment Configuration
# Copy this file to .env and fill in your values
# Never commit .env to version control

# Application
APP_ENV=local
USE_MOCK_DATA=false
LOG_LEVEL=INFO
SECRET_KEY=change_me_to_a_random_secret_key_32chars

# PostgreSQL
POSTGRES_DB=trading_os
POSTGRES_USER=trading_os
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+psycopg://trading_os:change_me@postgres:5432/trading_os

# Redis
REDIS_URL=redis://redis:6379/0

# Qdrant Vector DB
QDRANT_URL=http://qdrant:6333

# Trading Safety (DO NOT CHANGE defaults without understanding the risks)
TRADING_MODE=paper
LIVE_TRADING_ENABLED=false
REQUIRE_MANUAL_CONFIRMATION=true
KILL_SWITCH_ENABLED=false

# Alpaca Trading API (paper trading)
# Get keys at: https://alpaca.markets/
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# Anthropic Claude AI
# Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_ENABLE_WEB_SEARCH=false
ANTHROPIC_ENABLE_WEB_FETCH=false
ANTHROPIC_ENABLE_PROMPT_CACHING=true
ANTHROPIC_ENABLE_BATCHES=false
ANTHROPIC_MAX_TOKENS=4096

# OpenAI (optional fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Local AI (Ollama)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# AI Provider Selection
LOCAL_AI_PROVIDER=ollama
DEFAULT_AI_PROVIDER=anthropic

# Reddit API (optional social monitoring)
# Get credentials at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=trading-os-local/1.0

# X / Twitter API (optional social monitoring)
X_BEARER_TOKEN=

# Telegram Alerts (optional)
# Maak een bot via @BotFather; stuur de bot een bericht en haal je chat_id op via getUpdates.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# News RSS Feeds (comma-separated URLs)
NEWS_FEEDS=https://feeds.reuters.com/reuters/businessNews,https://feeds.bloomberg.com/markets/news.rss,https://feeds.finance.yahoo.com/rss/2.0/headline
CRYPTO_NEWS_FEEDS=https://cointelegraph.com/rss,https://coindesk.com/arc/outboundfeeds/rss/

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# Dashboard PIN security (set a PIN to protect the dashboard on public VPS)
# Leave empty to disable PIN auth
DASHBOARD_PIN=

# Memory directory (for AI trade lessons)
MEMORY_DIR=/app/memory
