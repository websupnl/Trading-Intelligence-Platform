ARG CORS_ORIGINS
ARG ALPACA_BASE_URL
ARG SERVICE_FQDN_WEB
ARG NEXT_PUBLIC_API_URL
ARG ANTHROPIC_ENABLE_WEB_SEARCH
ARG SERVICE_URL_SCHEDULER
ARG SERVICE_FQDN_SCHEDULER
ARG SERVICE_URL_WEB
ARG SERVICE_FQDN_WORKER
ARG CRYPTO_NEWS_FEEDS
ARG TELEGRAM_BOT_TOKEN
ARG TELEGRAM_CHAT_ID
ARG DASHBOARD_PIN
ARG MEMORY_DIR
ARG ANTHROPIC_API_KEY
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci --legacy-peer-deps

FROM node:20-alpine AS builder
ARG COOLIFY_URL
ARG COOLIFY_FQDN
ARG POSTGRES_USER
ARG POSTGRES_PASSWORD
ARG LOG_LEVEL
ARG POSTGRES_DB
ARG TRADING_MODE
ARG ALPACA_DATA_URL
ARG ALPACA_API_KEY
ARG SECRET_KEY
ARG LIVE_TRADING_ENABLED
ARG KILL_SWITCH_ENABLED
ARG REQUIRE_MANUAL_CONFIRMATION
ARG ALPACA_SECRET_KEY
ARG REDDIT_CLIENT_ID
ARG REDDIT_CLIENT_SECRET
ARG REDDIT_USER_AGENT
ARG ANTHROPIC_MODEL
ARG ANTHROPIC_ENABLE_PROMPT_CACHING
ARG ANTHROPIC_MAX_TOKENS
ARG OLLAMA_BASE_URL
ARG OPENAI_API_KEY
ARG DEFAULT_AI_PROVIDER
ARG SERVICE_URL_QDRANT
ARG SERVICE_URL_API
ARG SERVICE_FQDN_API
ARG SERVICE_URL_WORKER
ARG SERVICE_FQDN_QDRANT
ARG NEWS_FEEDS
ARG X_BEARER_TOKEN
ARG CORS_ORIGINS
ARG ALPACA_BASE_URL
ARG SERVICE_FQDN_WEB
ARG NEXT_PUBLIC_API_URL
ARG ANTHROPIC_ENABLE_WEB_SEARCH
ARG SERVICE_URL_SCHEDULER
ARG SERVICE_FQDN_SCHEDULER
ARG SERVICE_URL_WEB
ARG SERVICE_FQDN_WORKER
ARG CRYPTO_NEWS_FEEDS
ARG TELEGRAM_BOT_TOKEN
ARG TELEGRAM_CHAT_ID
ARG DASHBOARD_PIN
ARG MEMORY_DIR
ARG ANTHROPIC_API_KEY
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .

ARG NEXT_PUBLIC_API_URL=http://localhost:8000
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

RUN npm run build

FROM node:20-alpine AS runner
ARG COOLIFY_URL
ARG COOLIFY_FQDN
ARG POSTGRES_USER
ARG POSTGRES_PASSWORD
ARG LOG_LEVEL
ARG POSTGRES_DB
ARG TRADING_MODE
ARG ALPACA_DATA_URL
ARG ALPACA_API_KEY
ARG SECRET_KEY
ARG LIVE_TRADING_ENABLED
ARG KILL_SWITCH_ENABLED
ARG REQUIRE_MANUAL_CONFIRMATION
ARG ALPACA_SECRET_KEY
ARG REDDIT_CLIENT_ID
ARG REDDIT_CLIENT_SECRET
ARG REDDIT_USER_AGENT
ARG ANTHROPIC_MODEL
ARG ANTHROPIC_ENABLE_PROMPT_CACHING
ARG ANTHROPIC_MAX_TOKENS
ARG OLLAMA_BASE_URL
ARG OPENAI_API_KEY
ARG DEFAULT_AI_PROVIDER
ARG SERVICE_URL_QDRANT
ARG SERVICE_URL_API
ARG SERVICE_FQDN_API
ARG SERVICE_URL_WORKER
ARG SERVICE_FQDN_QDRANT
ARG NEWS_FEEDS
ARG X_BEARER_TOKEN
ARG CORS_ORIGINS
